pub fn yield_cpu() {
    let switch_info = if let Some(sched) = SCHEDULER.lock().as_mut() {
        sched.pick_next()
    } else {
        None
    };

    if let Some((curr, next)) = switch_info {
        unsafe {
            // use crate::arch::context::Context;

            let final_curr = if curr.is_null() {
                &raw mut BOOT_CONTEXT as *mut _
            } else {
                curr
