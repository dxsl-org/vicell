+pub fn print_usize(n: usize) {
+    let mut buf = [0u8; 20];
+    let mut i = 0;
+    let mut num = n;
+    
+    if num == 0 {
+        print("0");
+        return;
+    }
+    
+    while num > 0 {
+        buf[i] = (num % 10) as u8 + b'0';
+        num /= 10;
+        i += 1;
+    }
+    
+    // Reverse
+    let mut start = 0;
+    let mut end = i - 1;
+    while start < end {
+        let tmp = buf[start];
+        buf[start] = buf[end];
+        buf[end] = tmp;
+        start += 1;
+        end -= 1;
+    }
+    
+    if let Ok(s) = core::str::from_utf8(&buf[..i]) {
+        print(s);
+    }
