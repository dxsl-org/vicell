// Async variant
async fn read_file(fs: &mut dyn AsyncFileSystem) {
    let mut file = fs.open_async("data.txt", OpenMode::Read).await?;
    let mut buf = [0u8; 1024];
    let n = file.read_async(&mut buf).await?;
}
```

