// Minimal 8x8 PC Font (IBM VGA Code Page 437 subset)
// Each u8 represents a row of pixels.

pub const FONT_WIDTH: usize = 8;
pub const FONT_HEIGHT: usize = 8;

pub fn get_glyph(c: char) -> &'static [u8] {
    let idx = c as usize;
    if idx < 32 || idx > 126 {
        return &FONT_DATA[0..8]; // Return block for unknown
    }
    &FONT_DATA[(idx - 32) * 8..(idx - 32) * 8 + 8]
}

// Block character (index 0 relative to offset)
static FONT_DATA: [u8; 768] = [
