#[no_mangle]
extern "C" fn trap_handler(trap_frame: &mut ViTrapFrame) {
    match trap_frame.scause {
        0x8000_0000_0000_0005 => timer_interrupt(),
        8 | 9 | 11 => syscall_handler(trap_frame),
        _ => panic!("Unhandled trap: {:?}", trap_frame),
    }
}
```

