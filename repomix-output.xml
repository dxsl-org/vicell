## Writing Cell Code

### Cell Structure

```rust
// cells/apps/myapp/src/main.rs
#![no_std]
#![no_main]
#![forbid(unsafe_code)]  // REQUIRED for Cells

extern crate alloc;
use ostd::prelude::*;

#[no_mangle]
pub extern "C" fn _start() -> ! {
    ostd::init();  // Initialize Cell runtime

    match main() {
        Ok(_) => ostd::exit(0),
        Err(e) => {
            ostd::println!("Error: {:?}", e);
            ostd::exit(1);
        }
    }
}

fn main() -> ViResult<()> {
