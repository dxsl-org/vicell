    let mut file = ostd::fs::open("/test.txt", OpenMode::Read)?;
    let mut buffer = [0u8; 256];
    let n = file.read(&mut buffer)?;

    ostd::println!("Read {} bytes", n);
    Ok(())
}

#[panic_handler]
fn panic(info: &core::panic::PanicInfo) -> ! {
    ostd::println!("PANIC: {}", info);
