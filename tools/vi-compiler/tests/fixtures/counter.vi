// Counter — canonical ViUI v2 demo component
component Counter {
    in-out property <int> count: 0;

    VerticalLayout {
        padding: 16px;
        spacing: 8px;

        Text { text: "Count: \{count}"; color: #ffffff; }
        Button {
            text: "Increment";
            clicked => { count += 1; }
        }
    }
}
